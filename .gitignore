# ==========================================
# Dependencias de Node (¡Crucial!)
# ==========================================
# Aquí dentro vive Electron y todas sus librerías. 
# Son miles de archivos que cualquiera puede descargar corriendo 'npm install'.
node_modules/
jspm_packages/

# ==========================================
# Carpetas de Compilación y Distribución
# ==========================================
# Estas carpetas se crean cuando usas herramientas como 'electron-builder' 
# o 'electron-forge' para empaquetar tu app en un ejecutable.
dist/
build/
out/
.webpack/

# ==========================================
# Archivos de Registro y Logs de Error
# ==========================================
# Si tu app o npm fallan, crean estos archivos de texto con el historial del error.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# Configuraciones del Sistema Operativo
# ==========================================
# Archivos basura que Windows y Mac crean automáticamente para previsualizar carpetas.
.DS_Store
Thumbs.db

# ==========================================
# Entorno de Desarrollo (Opcional pero recomendado)
# ==========================================
# Oculta carpetas de configuración interna de editores como VS Code
.vscode/
.idea/


*.db